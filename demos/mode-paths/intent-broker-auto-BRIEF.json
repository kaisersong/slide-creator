        "visual": "event flow"
      },
      {
        "slide_number": 7,
        "role": "architecture",
        "title": "六个核心组件围绕 event store 工作",
        "key_point": "本地单进程 broker 已足够构成 v1",
        "visual": "architecture diagram"
      },
      {
        "slide_number": 8,
        "role": "verification",
        "title": "先验证闭环，再考虑远程化和 UI",
        "key_point": "协议、路由、可靠性、集成四层测试收束到可落地路径",
        "visual": "test matrix"
      }
    ]
