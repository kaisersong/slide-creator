        "visual": "scope boundary"
      },
      {
        "slide_number": 4,
        "role": "core-concepts",
        "title": "系统围绕五个对象组织",
        "key_point": "Participant、Intent、Task、Thread、Approval 形成骨架",
        "visual": "concept graph"
      },
      {
        "slide_number": 5,
        "role": "state-machines",
        "title": "状态由 intent 事件推进",
