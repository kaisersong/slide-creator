      "reliability",
      "architecture",
      "verification"
    ],
    "slides": [
      {
        "slide_number": 1,
        "role": "cover",
        "title": "Intent Broker",
        "key_point": "本地优先、多 agent 协作协议中间层",
        "visual": "hero metrics"
      },
      {
        "slide_number": 2,
        "role": "problem",
        "title": "现有协作方式缺少稳定任务语义",
        "key_point": "任务流不可审计、上下文易断、接入成本高",
        "visual": "pain list"
      },
      {
        "slide_number": 3,
        "role": "definition",
        "title": "Broker 只负责协议与可靠投递",
