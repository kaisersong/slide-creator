{
  "schema_version": 1,
  "brief_id": "preset-surface-phase1-swiss-modern",
  "mode": "auto",
  "language": "zh-CN",
  "title": "Agent Delivery Review",
  "audience": "需要判断 agent 交付路径是否可推广的工程负责人和产品负责人",
  "desired_action": "确认当前工作流适合扩展到更多高频交付场景",
  "deck": {
    "deck_type": "user-content",
    "page_count": 8,
    "output_format": "html-slides"
  },
  "style": {
    "preset": "Swiss Modern",
    "tone": "清晰、克制、偏咨询式判断",
    "visual_density": "medium"
  },
  "content": {
    "source_policy": "distill-only",
    "must_include": [
      "当前收益来自交付链路重排",
      "模板和验收门禁要比更多 agent 更重要",
      "下一阶段应先扩展高频稳定场景"
    ],
    "must_avoid": [
      "空泛效率口号",
      "无证据的能力夸张",
      "连续标题墙"
    ]
  },
  "narrative": {
    "thesis": "agent 交付的价值不在更多自动化角色，而在把需求澄清、实现、验收和复盘压缩成一个更短、更可验证的默认链路。",
    "page_roles": [
      "cover",
      "problem",
      "baseline",
      "workflow",
      "evidence",
      "tradeoff",
      "decision",
      "closing"
    ],
    "slides": [
      {
        "slide_number": 1,
        "role": "cover",
        "title": "交付提速来自链路重排，不只是多一个 agent",
        "key_point": "把澄清、实现、验收和复盘压到同一条工作流里，收益才会稳定出现",
        "visual": "hero statement"
      },
      {
        "slide_number": 2,
        "role": "problem",
        "title": "如果任务边界不清，agent 只会把返工提得更快",
        "key_point": "需求含混、验收缺位和上下文断裂，会把自动化放大成更多噪声",
        "visual": "risk contrast"
      },
      {
        "slide_number": 3,
        "role": "baseline",
        "title": "当前最好用的路径，是先把输入和门禁固定下来",
        "key_point": "模板、参考实现和验收标准比额外抽象层更直接决定结果稳定性",
        "visual": "baseline cards"
      },
      {
        "slide_number": 4,
        "role": "workflow",
        "title": "一个可复用链路至少包含四段",
        "key_point": "澄清输入、执行产出、校验结果、记录复盘必须在同一轮内闭合",
        "visual": "four-step workflow"
      },
      {
        "slide_number": 5,
        "role": "evidence",
        "title": "稳定场景先做深，比同时铺开多个实验更有效",
        "key_point": "高频、低耦合、可验证的任务更适合作为第一批标准化路径",
        "visual": "evidence matrix"
      },
      {
        "slide_number": 6,
        "role": "tradeoff",
        "title": "速度提升必须换来更强的验收，而不是更弱的判断",
        "key_point": "把 reviewer 从重复执行中解放出来，不等于把质量判断整体省掉",
        "visual": "tradeoff table"
      },
      {
        "slide_number": 7,
        "role": "decision",
        "title": "下一阶段应优先复制高频稳定场景",
        "key_point": "先把已经跑通的工作流扩展到相邻任务，再处理边缘场景",
        "visual": "decision roadmap"
      },
      {
        "slide_number": 8,
        "role": "closing",
        "title": "更短的交付链路，才是 agent 团队真正的复利",
        "key_point": "团队应该把复利押在可复用工作流和门禁，而不是押在更多即兴自动化",
        "visual": "closing signal"
      }
    ]
  },
  "runtime": {
    "editing_mode": true,
    "presenter_mode": true,
    "watermark_mode": "injected-last-slide",
    "export_intent": "none"
  },
  "plan_view": {
    "emit_planning_view": false,
    "planning_view_path": "PLANNING.md"
  },
  "timing": {
    "estimate": {
      "plan": "1-2 min",
      "generate": "1-3 min",
      "validate": "<1 min",
      "polish": "0-2 min",
      "total": "3-6 min"
    },
    "actual": {
      "plan": "0m 00s",
      "generate": "0m 00s",
      "validate": "0m 00s",
      "polish": "0m 00s",
      "total": "0m 00s"
    }
  },
  "notes": ""
}
